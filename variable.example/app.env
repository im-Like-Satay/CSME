# app
DOMAIN_HOST=app_domain_host

# postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=my_db
POSTGRES_USER=my_user

# memcached
MEMCACHED_HOST=memcached
MEMCACHED_PORT=11211

# JWT
JWT_SECRET_KEY=                    # Generate a secure key using: openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXP=900           # In seconds (15 minutes)
JWT_REFRESH_TOKEN_SHORT_EXP=86400  # In seconds (1 day)
JWT_REFRESH_TOKEN_LONG_EXP=2592000 # In seconds (30 days)

# Google OAuth, get from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
OAUTH_STATE_TTL=300                # In seconds (5 minutes), TTL for OAuth state cookie/cache

# Rate limiting
RATE_LIMIT_LOGIN=5                 # Max attempts per window
RATE_LIMIT_SIGNUP=3                # Max attempts per window
RATE_LIMIT_WINDOW=60               # Window size in seconds